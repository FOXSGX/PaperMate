# ---- Server (与前端 Vite 代理目标一致) ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ---- LLM（可选；未配置时使用规则/模板降级）----
LLM_API_KEY=
LLM_MODEL=deepseek-chat

# ---- Data dirs（相对 backend/ 根目录解析）----
CHROMA_PERSIST_DIR=./data/chroma_db
UPLOAD_DIR=./data/uploads
INDEX_DIR=./data/indexes
OUTPUT_DIR=./data/outputs
MAX_UPLOAD_MB=30
